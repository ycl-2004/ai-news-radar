# AI News Radar advanced source template
# Copy values into your local shell or GitHub Secrets/Variables.
# Do not commit real secrets.

# AgentMail: metadata-only newsletter digest. Default: off.
# Demo source: subscribe one AgentMail inbox to https://alphasignal.ai/ and filter to AlphaSignal sender domains.
EMAIL_DIGEST_ENABLED=0
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_LIMIT=10
AGENTMAIL_ALLOWED_SENDER_DOMAINS=alphasignal.ai
# Only publish data/email-digest.json when you explicitly want a public digest.
EMAIL_DIGEST_PUBLISH=0

# X API: official API recent search. Default: off.
# X API no longer has an official free read quota in the checked docs; reads consume paid credits.
# Single-account demo query: @rileybrown, at most 10 returned posts, about $0.05 max per run.
X_API_ENABLED=0
X_BEARER_TOKEN=
X_API_QUERY='from:rileybrown -is:retweet -is:reply'
X_API_MAX_RESULTS=10
X_API_DAILY_POST_LIMIT=10
# The GitHub workflow runs every 30 minutes. This gate keeps X reads to one daily window.
X_API_RUN_UTC_HOUR=0
X_API_RUN_UTC_MINUTE_MAX=10

# SocialData.tools: third-party X/Twitter public-data API. Default: off.
# Store SOCIALDATA_API_KEY only as a local env var or GitHub Secret.
# Search pricing is usage-based per tweet returned, so keep an interval gate and small cap.
SOCIALDATA_ENABLED=0
SOCIALDATA_API_KEY=
SOCIALDATA_QUERY='(AI OR "artificial intelligence" OR "large language model" OR LLM) lang:en -filter:retweets'
SOCIALDATA_SEARCH_TYPE=Latest
SOCIALDATA_MAX_RESULTS=20
SOCIALDATA_DAILY_TWEET_LIMIT=20
SOCIALDATA_RUN_INTERVAL_HOURS=12
SOCIALDATA_RUN_UTC_HOUR=0
SOCIALDATA_RUN_UTC_MINUTE_MAX=30
SOCIALDATA_FORCE_RUN=0

# TikHub: paid third-party Douyin + Xiaohongshu public search API. Default: off.
# Store TIKHUB_API_KEY only as a local env var or GitHub Secret.
# Query is comma-separated; keep caps small because each platform/keyword request can be billed.
TIKHUB_ENABLED=0
TIKHUB_API_KEY=
TIKHUB_API_BASE_URL=https://api.tikhub.io
TIKHUB_FORCE_RUN=0
TIKHUB_QUERY='AI,人工智能,大模型,OpenAI,Claude,Agent,AI工具'
TIKHUB_PLATFORMS=douyin,xiaohongshu
TIKHUB_MAX_RESULTS=20
TIKHUB_DAILY_ITEM_LIMIT=20
TIKHUB_RUN_INTERVAL_HOURS=24
TIKHUB_RUN_UTC_HOUR=0
TIKHUB_RUN_UTC_MINUTE_MAX=10
